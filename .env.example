# GreenPOS Backend Configuration
# Copy this file to .env and update with your values

# ===========================================
# Server Configuration
# ===========================================
PORT=8080
ENV=development
LOG_LEVEL=info

# ===========================================
# Database Configuration
# ===========================================
DATABASE_URL=postgres://user:password@localhost:5432/greenpos?sslmode=disable

# Connection pool settings (optional - defaults are usually fine)
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=30m

# Separate database URL for migrations (optional)
# MIGRATE_DATABASE_URL=postgres://user:password@localhost:5432/greenpos?sslmode=disable

# ===========================================
# JWT Configuration
# ===========================================
# IMPORTANT: Change this secret in production! Use a long random string (32+ chars)
JWT_SECRET=your-very-long-random-secret-key-change-in-production

# Token expiry settings
JWT_EXPIRY_HOURS=24
REFRESH_TOKEN_EXPIRY_DAYS=7

# ===========================================
# Security Configuration
# ===========================================
# Bcrypt cost factor (higher = more secure but slower)
# Valid range: 4-31, default is 10
BCRYPT_COST=12

# Rate limiting (requests per minute per IP)
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# CORS allowed origins (comma-separated for multiple)
# Use * for all origins (development only)
CORS_ALLOWED_ORIGINS=*

# ===========================================
# Example Production Configuration
# ===========================================
# PORT=8080
# ENV=production
# LOG_LEVEL=info
# DATABASE_URL=postgres://greenpos_user:secure_password@db.example.com:5432/greenpos?sslmode=require
# JWT_SECRET=a-very-long-random-secret-key-at-least-32-characters-long
# JWT_EXPIRY_HOURS=24
# REFRESH_TOKEN_EXPIRY_DAYS=7
# BCRYPT_COST=12
# RATE_LIMIT_REQUESTS_PER_MINUTE=100
# CORS_ALLOWED_ORIGINS=https://yourpos.example.com
